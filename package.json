{
  "name": "api-filmes",
  "version": "1.0.0",
  "description": "api de filmes",
  "keywords": [
    "api",
    "filmes"
  ],
  "license": "ISC",
  "author": "Joelmir & Jalmir",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "dev": "node --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint src/**",
    "lint:fix": "eslint src/** --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.39",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "supertest": "^7.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
